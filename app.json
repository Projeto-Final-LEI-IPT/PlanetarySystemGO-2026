{
  "expo": {
    "name": "PlanetarySystemGo",
    "slug": "PlanetarySystemGo",
    "version": "1.0.0",
    "icon": "./assets/icon.jpeg",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.jpeg",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "package": "com.pedro.planetarysystemgo"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "A aplicação necessita de aceder à câmara para a experiência de realidade aumentada."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "A aplicação necessita do GPS para as funcionalidades de localização."
        }
      ],
      "expo-web-browser"
    ]
  }
}
